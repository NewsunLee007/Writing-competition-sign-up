# 服务器配置
PORT=8000
NODE_ENV=development
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# 数据库配置 (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-misty-scene-123456.us-east-2.aws.neon.tech/ruian_contest?sslmode=require
DB_HOST=ep-misty-scene-123456.us-east-2.aws.neon.tech
DB_PORT=5432
DB_NAME=ruian_contest
DB_USER=user
DB_PASSWORD=password

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# 文件上传配置
MAX_FILE_SIZE=10485760 # 10MB
UPLOAD_DIR=uploads/

# Email 配置 (用于发送验证邮件)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@ruian-writing-contest.com

# 安全配置
RATE_LIMIT_WINDOW_MS=15*60*1000 # 15分钟
RATE_LIMIT_MAX=100 # 每个IP 15分钟内最多100次请求

# CORS 配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173

# API 密钥 (可选)
# GOOGLE_CAPTCHA_SECRET=your-google-captcha-secret