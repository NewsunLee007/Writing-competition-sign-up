{
  "version": 2,
  "builds": [
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/contest.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/contest/(.*)",
      "dest": "/api/contest.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}